{
  "research_topic": "AI-assisted literature reviews",
  "research_question": "Can a stronger open-weight reasoning model improve paper screening quality?",
  "review_objective": "Benchmark a larger free local model for paper relevance decisions.",
  "inclusion_criteria": [
    "mentions systematic review or evidence synthesis",
    "evaluates LLMs or screening automation"
  ],
  "exclusion_criteria": [
    "no abstract available",
    "not relevant to review workflows"
  ],
  "search_keywords": [
    "large language models",
    "screening",
    "systematic review",
    "evidence synthesis"
  ],
  "boolean_operators": "AND",
  "pages_to_retrieve": 2,
  "results_per_page": 20,
  "year_range_start": 2020,
  "year_range_end": 2026,
  "max_papers_to_analyze": 20,
  "citation_snowballing_enabled": true,
  "relevance_threshold": 70,
  "download_pdfs": true,
  "analyze_full_text": true,
  "full_text_max_chars": 12000,
  "llm_provider": "huggingface_local",
  "openalex_enabled": true,
  "semantic_scholar_enabled": true,
  "crossref_enabled": true,
  "include_pubmed": false,
  "max_workers": 1,
  "request_timeout_seconds": 60,
  "resume_mode": true,
  "disable_progress_bars": false,
  "title_similarity_threshold": 0.92,
  "data_dir": "data/local_hf_gpt_oss_run",
  "papers_dir": "papers/local_hf_gpt_oss_run",
  "results_dir": "results/local_hf_gpt_oss_run",
  "database_path": "data/local_hf_gpt_oss_run/literature_review.db",
  "api_settings": {
    "crossref_mailto": "you@example.com",
    "unpaywall_email": "you@example.com",
    "huggingface_model": "openai/gpt-oss-20b",
    "huggingface_task": "text-generation",
    "huggingface_device": "auto",
    "huggingface_dtype": "auto",
    "huggingface_max_new_tokens": 800,
    "huggingface_trust_remote_code": false,
    "llm_temperature": 0.1
  }
